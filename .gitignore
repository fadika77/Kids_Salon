# ═══════════ Python / Backend ═══════════
__pycache__/
*.py[cod]
*$py.class
venv/
env/
.venv/
*.egg-info/
.pytest_cache/
.mypy_cache/

# ═══════════ Secrets — NEVER commit these ═══════════
.env
backend/.env
backend/firebase-credentials.json

# ═══════════ Databases ═══════════
*.db
*.sqlite
*.sqlite3

# ═══════════ Node / Frontend ═══════════
node_modules/
frontend/dist/
frontend/.vite/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ═══════════ Capacitor — Android ═══════════
frontend/android/.gradle/
frontend/android/build/
frontend/android/app/build/
frontend/android/app/release/
frontend/android/local.properties
frontend/android/.idea/
frontend/android/captures/
frontend/android/*.iml
frontend/android/app/*.iml

# ═══════════ Capacitor — iOS (for the future) ═══════════
frontend/ios/App/Pods/
frontend/ios/App/App.xcworkspace/xcuserdata/
frontend/ios/App/App.xcodeproj/xcuserdata/
frontend/ios/DerivedData/

# ═══════════ OS / Editor junk ═══════════
.DS_Store
Thumbs.db
Desktop.ini
*.swp
.idea/